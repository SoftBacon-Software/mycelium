  "license": "AGPL-3.0-only",
  "repository": "https://github.com/SoftBacon-Software/mycelium",
  "homepage": "https://mycelium.fyi",
  "workspaces": [
    "mcp",
    "runner",
    "printer-drone",
    "sdk"
