    "express": "^4.18.0",
    "googleapis": "^171.4.0",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.0",
    "resend": "^6.9.3",
    "stripe": "^20.4.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.7",
    "supertest": "^7.2.2",
    "vitest": "^4.1.7"
