{
  "name": "mycelium-agent-sdk",
  "version": "1.0.0",
  "description": "Connect any AI agent to the Mycelium network -- multi-runtime orchestration, work queues, inter-agent messaging, and platform adapters with zero dependencies",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./agent": "./src/agent.js",
    "./api": "./src/api.js",
    "./adapters/discord": "./adapters/discord.js",
    "./adapters/slack": "./adapters/slack.js",
    "./adapters/voice": "./adapters/voice.js"
  },
  "bin": {
    "mycelium-agent": "./bin/run.js",
    "mycelium-init": "./bin/init.js"
  },
  "scripts": {
    "start": "node bin/run.js"
  },
  "keywords": [
    "mycelium",
    "ai",
    "agents",
    "ai-agents",
    "multi-agent",
    "orchestration",
    "multi-runtime",
    "sdk",
    "llm",
    "swarm",
    "distributed",
    "task-queue",
    "inter-agent",
    "claude",
    "mcp"
  ],
  "author": "SoftBacon Software <hello@mycelium.fyi> (https://mycelium.fyi)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SoftBacon-Software/mycelium.git",
    "directory": "sdk"
  },
  "bugs": {
    "url": "https://github.com/SoftBacon-Software/mycelium/issues"
  },
  "homepage": "https://mycelium.fyi",
  "optionalDependencies": {
    "ws": "^8.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "src/",
    "bin/",
    "adapters/",
    "examples/",
    "README.md",
    "LICENSE"
  ]
}
