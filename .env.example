# Mycelium — Environment Variables
# Copy this file to .env and fill in the values.

# Required: JWT signing secret for dashboard authentication
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Required: Admin API key for privileged operations
# Generate: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
ADMIN_KEY=

# Optional: Server port (default: 3002)
# PORT=3002

# Optional: Database and file storage directory (default: server/data/)
# Only set this if you have a persistent volume mounted (e.g. Railway volume at /data)
# Setting DATA_DIR=/data without a volume will crash on startup (EACCES)
# DATA_DIR=/data

# Optional: WebRTC TURN secret for voice chat
# Without this, a public relay is used (fine for development, not for production)
# TURN_SECRET=

# Optional: Set to production for deployed instances
# NODE_ENV=production
